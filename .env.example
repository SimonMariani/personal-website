# Shared environment for the whole stack. Injected into both the API and the postgres container via `env_file` in docker-compose, so credentials live in a single place.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=documents

# Optional connection overrides (defaults: host=postgres, port=5432)
# PG_HOST=postgres
# PG_PORT=5432

# Remaining environment variables
OPENAIKEY=
DEBUG=true
